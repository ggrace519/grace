{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    /**
     * allowJs so .svelte can import .js; checkJs false to avoid strict typing in plain .js.
     * Svelte/TS files are still type-checked.
     */
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "noImplicitAny": false,
    "strict": false
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
